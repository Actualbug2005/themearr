RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here
# Optional: map Radarr paths to paths inside this container.
# Format: source=target;source2=target2
# Example: RADARR_PATH_MAP=/radarr/media=/movies
# RADARR_PATH_MAP=
# Optional: set your upstream repository for update checks.
# GITHUB_REPO=Actuallbug2005/themearr
# Optional: override the command used by /api/update.
# THEMEARR_UPDATER_CMD=sudo /usr/local/bin/themearr-update
# Optional: override the default DB path
# DB_PATH=/opt/themearr/data/themearr.db
